# ─────────────────────────────────────────────────────────────────
#  VoltVanguard Route Optimizer — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=voltvanguard-ai-agent-group

# Topic name — must match the topic created by Spring Boot (Phase 2).
# Phase 2 created: telemetry.raw  |  adjust if you renamed it.
KAFKA_TELEMETRY_TOPIC=telemetry.raw
KAFKA_ALERTS_TOPIC=vehicle.alerts
KAFKA_DLQ_TOPIC=telemetry.raw.DLT

# ── VoltVanguard Backend API ───────────────────────────────────────
BACKEND_BASE_URL=http://localhost:8080/api/v1
BACKEND_TIMEOUT_SECONDS=10
BACKEND_MAX_RETRIES=3

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # cheaper for high-frequency inference
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.1            # low temp = deterministic decisions
OPENAI_TIMEOUT_SECONDS=15

# ── Decision Engine ───────────────────────────────────────────────
# Battery thresholds (%)
BATTERY_CRITICAL_THRESHOLD=15.0
BATTERY_LOW_THRESHOLD=25.0
BATTERY_PROACTIVE_THRESHOLD=35.0  # suggest charging before it becomes urgent

# Station search radius (km)
STATION_SEARCH_RADIUS_KM=30.0
STATION_MAX_RESULTS=5

# Use LLM for borderline decisions (battery between LOW and PROACTIVE thresholds)
LLM_ENABLED=true

# Minimum minutes between reservations for the same vehicle (dedup guard)
RESERVATION_COOLDOWN_MINUTES=30

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/route-optimizer.log
LOG_ROTATION=50 MB
LOG_RETENTION=7 days
LOG_SERIALIZE_JSON=false          # true for production log aggregators (ELK/Loki)

# ── Agent Identity ────────────────────────────────────────────────
AGENT_ID=route-optimizer-1        # unique per replica for multi-instance deployments
